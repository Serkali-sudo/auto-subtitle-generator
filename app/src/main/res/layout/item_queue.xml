<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/queueSelectCB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:visibility="gone" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/queueThumbIV"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginEnd="12dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ri_file_video_line"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Small" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/queueTitleTV"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/queueEditBT"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ri_edit_line"
                        android:tint="?attr/colorPrimary"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Edit in Preview" />
                </LinearLayout>

                <TextView
                    android:id="@+id/queueStatusTV"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:alpha="0.75"
                    android:textSize="13sp" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/queueProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/queueOutputTV"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:alpha="0.78"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fillViewport="false"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/queueExportVideoBT"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:contentDescription="Export video"
                android:text="Export video"
                android:visibility="gone"
                app:icon="@drawable/ri_file_video_line"
                app:iconGravity="textStart"
                app:iconPadding="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/queueExportSubtitleBT"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:contentDescription="Save subtitles"
                android:text="Export subs"
                android:visibility="gone"
                app:icon="@drawable/ri_file_text_line"
                app:iconGravity="textStart"
                app:iconPadding="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/queueShareBT"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:contentDescription="Share"
                android:text="Share"
                android:visibility="gone"
                app:icon="@drawable/ri_share_line"
                app:iconGravity="textStart"
                app:iconPadding="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/queuePlayBT"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:contentDescription="Play"
                android:text="Play"
                android:visibility="gone"
                app:icon="@drawable/ri_play_circle_line"
                app:iconGravity="textStart"
                app:iconPadding="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/queueRetryBT"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:contentDescription="Retry"
                android:text="Retry"
                android:visibility="gone"
                app:icon="@drawable/ri_restart_line"
                app:iconGravity="textStart"
                app:iconPadding="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/queueRemoveBT"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:contentDescription="Remove"
                android:text="Del"
                app:icon="@drawable/ri_delete_bin_line"
                app:iconGravity="textStart"
                app:iconPadding="4dp" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
