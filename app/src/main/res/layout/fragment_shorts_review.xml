<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp">

    <FrameLayout
        android:id="@+id/shortPlayerFrame"
        android:layout_width="146dp"
        android:layout_height="260dp"
        android:layout_marginEnd="12dp"
        android:background="@android:color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.media3.ui.PlayerView
            android:id="@+id/shortPlayerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:resize_mode="fill"
            app:show_buffering="when_playing"
            app:surface_type="texture_view" />

        <com.serhat.autosub.FaceTrackingOverlayView
            android:id="@+id/faceTrackingOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/reviewControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/shortPlayerFrame"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/currentCandidateTitleTV"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select a candidate"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/currentCandidateTimeTV"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.75"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Horizontal framing"
            android:textStyle="bold" />

        <com.google.android.material.slider.Slider
            android:id="@+id/cropSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:value="0.5"
            android:valueFrom="0"
            android:valueTo="1"
            app:labelBehavior="withinBounds" />

        <TextView
            android:id="@+id/cropHintTV"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.7"
            android:gravity="center"
            android:text="Centered"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/autoFrameBT"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="Auto frame speaker" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/exportSelectedBT"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:text="Export selected"
            app:icon="@drawable/ri_export_line" />
    </LinearLayout>

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/reviewHeaderBottomBarrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="shortPlayerFrame,reviewControls" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/shortsProgress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/reviewHeaderBottomBarrier" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/candidatesRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shortsProgress" />
</androidx.constraintlayout.widget.ConstraintLayout>
