<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="2dp"
    android:layout_marginTop="4dp"
    android:layout_marginEnd="2dp"
    android:layout_marginBottom="4dp"
    android:background="@drawable/subtitle_item_background"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/numberTV"
            android:layout_width="38dp"
            android:layout_height="32dp"
            android:background="@drawable/subtitle_number_background"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/timeTV"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:alpha="0.78"
            android:ellipsize="end"
            android:maxLines="1"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/playBT"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:selectableItemBackgroundBorderless"
            android:contentDescription="Play"
            android:padding="8dp"
            android:src="@drawable/ri_play_circle_line" />

        <ImageButton
            android:id="@+id/editBT"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:selectableItemBackgroundBorderless"
            android:contentDescription="Edit"
            android:padding="8dp"
            android:src="@drawable/ri_edit_line" />

        <ImageButton
            android:id="@+id/deleteBT"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:selectableItemBackgroundBorderless"
            android:contentDescription="Delete"
            android:padding="8dp"
            android:src="@drawable/ri_delete_bin_line" />
    </LinearLayout>

    <TextView
        android:id="@+id/textTV"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="2dp"
        android:textSize="16sp" />

</LinearLayout>
